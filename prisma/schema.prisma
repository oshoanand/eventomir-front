generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["views"]
}

datasource db {
  provider = "postgresql"
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED_BY_CUSTOMER
}

enum NotificationType {
  SYSTEM
  NEW_MESSAGE
  ADMIN_ALERT

  NEW_BOOKING
  BOOKING_REQUEST
  BOOKING_UPDATE
  BOOKING_ACCEPTED
  BOOKING_REJECTED

  // Performer related
  MODERATION_UPDATE
  NEW_REQUEST

  // Partner related
  PARTNER_REQUEST
  PARTNER_APPROVED
  PAYOUT_REQUEST

  SUPPORT_TICKET
  SUPPORT_UPDATE
}

enum SubscriptionTier {
  FREE
  STANDARD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum WalletType {
  PAYMENT
  TOPUP
  REFUND
  PAYOUT
}

enum OrderStatus {
  INITIATED // Order created, waiting for user action
  AWAITING_BANK_TRANSFER // NEW: B2B invoice generated, waiting for wire transfer
  ACTIVE // Ticket is valid and ready to use
  PAYMENT_SUCCESS // Payment cleared (alternative to ACTIVE depending on your logic)
  PAYMENT_FAILED // Card declined or Tinkoff error
  CANCELLED // Order manually cancelled or expired
  PAYMENT_PENDING
  EXPIRED
}

enum PaymentMethod {
  CARD // Standard B2C Tinkoff acquiring
  INVOICE // Standard B2B Wire Transfer (Оплата по счету)
}

enum TargetType {
  topic
  token
}

enum FCMStatus {
  SUCCESS
  FAILED
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

enum EventType {
  PUBLIC
  PRIVATE
}

enum PaymentType {
  FREE
  PAID
}

enum RsvpStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum DiscountType {
  PERCENTAGE
  FLAT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_ON_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketType {
  BUG_REPORT
  FEATURE_REQUEST
  BILLING
  TECHNICAL_SUPPORT
  GENERAL_INQUIRY
  OTHER
}

// ==========================================
// USER & AUTHENTICATION MODELS
// ==========================================

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String?

  auth_provider               String            @default("credentials")
  name                        String?
  phone                       String?
  city                        String?
  image                       String?
  profile_picture             String?
  registration_date           DateTime          @default(now())
  role                        String?
  account_type                String?
  company_name                String?
  inn                         String?
  description                 String?
  background_picture          String?
  roles                       String[]
  price_range                 Int[]
  latitude                    Float?
  longitude                   Float?
  fcmToken                    String?
  subscription_plan_id        SubscriptionTier? @default(FREE)
  subscription_end_date       DateTime?
  moderation_status           String            @default("pending_approval")
  sub_profile_ids             String[]
  created_at                  DateTime          @default(now())
  updated_at                  DateTime          @updatedAt
  profile_picture_alt_text    String?
  background_picture_alt_text String?
  profile_meta_title          String?
  profile_meta_description    String?
  profile_keywords            String?
  details                     Json?
  status                      String?           @default("active")
  emailVerified               DateTime?
  experience                  String?
  resetPasswordToken          String?
  resetPasswordExpires        DateTime?
  favorite_performers         Json?
  welcomePushSent             Boolean           @default(false)

  referredById    String?
  referredBy      Partner? @relation("ReferredUsers", fields: [referredById], references: [id])
  partner_profile Partner? @relation("PartnerProfile")

  reviews_written       Review[]      @relation("CustomerReviews")
  reviews_received      Review[]      @relation("PerformerReviews")
  bookings_as_customer  Booking[]     @relation("CustomerBookings")
  bookings_as_performer Booking[]     @relation("PerformerBookings")
  paid_requests         PaidRequest[]
  gallery_items         GalleryItem[]

  support_requests_as_requester SupportTicket[] @relation("RequesterSupport")
  support_requests_as_manager   SupportTicket[] @relation("ManagerSupport")

  referral_events_as_referred ReferralEvent[] @relation("ReferredUser")

  favorites_given        Favorite[]             @relation("CustomerFavorites")
  favorites_received     Favorite[]             @relation("PerformerFavorites")
  certificates           Certificate[]
  recommendation_letters RecommendationLetter[]
  prompts                Prompt[]
  notifications          Notification[]
  subscription           UserSubscription?
  payments               Payment[]

  accounts           Account[]
  sessions           Session[]
  verificationTokens VerificationToken[]

  audio_tracks AudioTrack[]

  parentAgencyId String?
  parentAgency   User?   @relation("AgencySpecialists", fields: [parentAgencyId], references: [id])
  subProfiles    User[]  @relation("AgencySpecialists")

  events          Event[]
  orders          Order[]
  articleComments ArticleComment[]
  articleLikes    ArticleLike[]

  walletBalance      Float               @default(0)
  walletTransactions WalletTransaction[]

  // Relations for the universal chat
  chatsAsUser1   ChatSession[]   @relation("ChatUser1")
  chatsAsUser2   ChatSession[]   @relation("ChatUser2")
  messagesSent   ChatMessage[]
  usedPromoCodes PromoCode[]     @relation("PromoCodeUsers")
  supportTickets SupportTicket[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  expires      DateTime
  sessionToken String   @unique
  accessToken  String   @unique
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  id         String    @id @default(cuid())
  identifier String?
  userId     String?
  token      String    @unique
  expires    DateTime?
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([identifier, token])
}

// ==========================================
// CORE PLATFORM MODELS
// ==========================================

model Review {
  id               String    @id @default(cuid())
  performer_id     String
  customer_id      String
  customer_name    String
  author_id        String
  rating           Int
  comment          String?   @db.Text
  reply            String?   @db.Text
  reply_created_at DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @default(now()) @updatedAt

  performer User @relation("PerformerReviews", fields: [performer_id], references: [id], onDelete: Cascade)
  customer  User @relation("CustomerReviews", fields: [customer_id], references: [id], onDelete: Cascade)
}

model Booking {
  id      String        @id @default(uuid())
  date    DateTime
  details String?       @db.Text
  status  BookingStatus @default(PENDING)

  customerId String
  customer   User   @relation("CustomerBookings", fields: [customerId], references: [id], onDelete: Cascade)

  performerId String
  performer   User   @relation("PerformerBookings", fields: [performerId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  payments  Payment[]
}

model PaidRequest {
  id         String @id @default(uuid())
  customerId String
  customer   User   @relation(fields: [customerId], references: [id], onDelete: Cascade)

  category           String
  serviceDescription String  @db.Text
  city               String?
  budget             String?

  status String @default("PENDING_PAYMENT")

  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])

  views     Int @default(0)
  responses Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id           String   @id @default(cuid())
  customer_id  String
  performer_id String
  created_at   DateTime @default(now())

  customer  User @relation("CustomerFavorites", fields: [customer_id], references: [id], onDelete: Cascade)
  performer User @relation("PerformerFavorites", fields: [performer_id], references: [id], onDelete: Cascade)

  @@unique([customer_id, performer_id])
}

// ==========================================
// MEDIA & CONTENT MODELS
// ==========================================

model GalleryItem {
  id                String   @id @default(cuid())
  performer_id      String
  title             String
  description       String?  @db.Text
  image_urls        String[]
  moderation_status String   @default("pending_approval")
  meta_title        String?
  meta_description  String?
  keywords          String?
  image_alt_text    String?
  created_at        DateTime @default(now())

  performer User @relation(fields: [performer_id], references: [id], onDelete: Cascade)
}

model Certificate {
  id                String   @id @default(cuid())
  performer_id      String
  file_url          String
  description       String?  @db.Text
  moderation_status String   @default("pending_approval")
  created_at        DateTime @default(now())

  performer User @relation(fields: [performer_id], references: [id], onDelete: Cascade)
}

model RecommendationLetter {
  id                String   @id @default(cuid())
  performer_id      String
  file_url          String
  description       String?  @db.Text
  moderation_status String   @default("pending_approval")
  created_at        DateTime @default(now())

  performer User @relation(fields: [performer_id], references: [id], onDelete: Cascade)
}

// ==========================================
// COMMUNICATION & SUPPORT MODELS
// ==========================================

model ChatSession {
  id String @id @default(cuid())

  user1Id String
  user1   User   @relation("ChatUser1", fields: [user1Id], references: [id])

  user2Id String
  user2   User   @relation("ChatUser2", fields: [user2Id], references: [id])

  status   String        @default("OPEN")
  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supportTicket SupportTicket?

  @@unique([user1Id, user2Id])
}

model ChatMessage {
  id            String    @id @default(cuid())
  chatSessionId String
  senderId      String
  text          String?   @db.Text
  imageUrl      String?
  isRead        Boolean   @default(false)
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  replyToId String?
  replyTo   ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   ChatMessage[] @relation("MessageReplies")

  session ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  sender  User        @relation(fields: [senderId], references: [id], onDelete: Cascade)
}

// ==========================================
// ROBUST SUPPORT TICKET MODEL
// ==========================================
model SupportTicket {
  id String @id @default(cuid())

  // 1. Core Ticket Info
  ticket_number Int            @unique @default(autoincrement()) // Human-readable ID (e.g., #1042)
  subject       String // Short summary/title of the issue
  description   String         @db.Text // The initial detailed message
  type          TicketType     @default(GENERAL_INQUIRY)
  priority      TicketPriority @default(NORMAL)
  status        TicketStatus   @default(OPEN)

  // 2. Attachments / Evidence 
  // (Use JSON if MySQL/SQLite, String[] if PostgreSQL)
  attachments String[]

  // 3. Requester Info (Supports both Auth Users and Guests)
  requester_id   String? // Made optional to support guest tickets
  contact_mobile String? // Essential if requester_id is null
  contact_email  String? // Optional fallback contact

  // 4. Assignments & Workflow
  assigned_manager_id String?
  chat_id             String? @unique // Made optional: Chat might only be created IF admin initiates real-time session

  // 5. SLA & Timestamps
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  first_response_at DateTime? // Tracks how fast admin replied
  resolved_at       DateTime? // Tracks how fast issue was fixed
  closed_at         DateTime? // When ticket is archived/locked

  // 6. Relations
  requester        User?        @relation("RequesterSupport", fields: [requester_id], references: [id], onDelete: SetNull)
  assigned_manager User?        @relation("ManagerSupport", fields: [assigned_manager_id], references: [id], onDelete: SetNull)
  chat             ChatSession? @relation(fields: [chat_id], references: [id], onDelete: SetNull)
  user             User?        @relation(fields: [userId], references: [id])
  userId           String?

  // 7. Database Indexes for Admin Dashboard Performance
  @@index([status, priority])
  @@index([created_at])
  @@index([requester_id])
  @@index([assigned_manager_id])
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  title  String @db.VarChar(255)

  message   String           @db.Text
  type      NotificationType
  data      Json? // Stores dynamic payload like { "url": "/bookings/123", "bookingId": "123" }
  link      String? // Optional: You can keep this, though we pass 'url' inside the 'data' JSON now
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
}

// ==========================================
// FINANCIAL & SUBSCRIPTION MODELS
// ==========================================

model Payment {
  id           String        @id @default(uuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Int
  currency     String        @default("RUB")
  status       PaymentStatus @default(PENDING)
  provider     String
  providerTxId String?
  metadata     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking   Booking? @relation(fields: [bookingId], references: [id])
  bookingId String?

  paidRequest PaidRequest?
}

// ==========================================
// SUBSCRIPTION PLANS
// ==========================================

model SubscriptionPlan {
  id              String           @id @default(uuid())
  name            String
  description     String           @db.Text
  tier            SubscriptionTier @unique
  priceMonthly    Int              @default(0)
  priceHalfYearly Int?             @default(0)
  priceYearly     Int?             @default(0)

  features Json @default("{}")

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions UserSubscription[]
}

model UserSubscription {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  planId String
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  startDate DateTime  @default(now())
  endDate   DateTime?

  status SubscriptionStatus @default(ACTIVE) // "ACTIVE", "EXPIRED", "CANCELLED"

  pricePaid Float?

  // 🚨 NEW: Track the Promo Code used for this subscription cycle
  promoCodeId String?
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id], onDelete: SetNull)

  // 🚨 NEW: Store the exact discount amount applied at the time of purchase
  // (Protects financial data if the PromoCode is later modified/deleted by an admin)
  discountAmount Float?

  autoRenew Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// EVENTS & BLOG MODELS
// ==========================================

