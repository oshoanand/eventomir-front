model Event {
  id       String @id @default(cuid())
  title    String
  category String

  // --- New Privacy & Payment Fields ---
  type          EventType   @default(PRIVATE)
  paymentType   PaymentType @default(FREE)
  price         Float       @default(0)
  discountPrice Float?      @default(0)

  // --- Details ---
  date        DateTime
  time        String?
  city        String
  address     String?
  imageUrl    String
  description String?  @db.Text

  // --- Ticket Data ---
  totalTickets     Int    @default(0)
  availableTickets Int    @default(0)
  status           String @default("active")

  // --- Relations ---
  hostId      String?
  host        User?        @relation(fields: [hostId], references: [id], onDelete: Cascade)
  orders      Order[]
  invitations Invitation[] // New: Links the event to its RSVPs/Guests

  // --- Timestamps ---
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invitation {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)

  guestName  String
  guestEmail String
  guestPhone String?

  status RsvpStatus @default(PENDING)

  // --- Security for Check-in ---
  ticketToken String    @unique @default(uuid())
  isCheckedIn Boolean   @default(false)
  checkInTime DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Prevents a user from RSVPing multiple times to the same event with the same email
  @@unique([eventId, guestEmail])
}

model Order {
  id      String @id @default(cuid())
  eventId String
  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  ticketCount   Int
  totalPrice    Float
  status        OrderStatus   @default(INITIATED)
  paymentId     String? // Stores Tinkoff's internal PaymentId
  paymentMethod PaymentMethod @default(CARD)

  ticketCode String    @unique @default(uuid()) // Embedded in the QR Code
  isUsed     Boolean   @default(false) // Has the attendee scanned in?
  enteredAt  DateTime? // Exact timestamp they entered

  // --- NEW: B2B Invoice Fields (ООО / ИП) ---
  invoiceNumber String?   @unique // e.g., "INV-171353-991" (Null for B2C card payments)
  dueDate       DateTime? // Deadline for the bank transfer (e.g., +5 days)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 🚨 Add these Enums to the bottom of your schema.prisma file

model Article {
  id               String   @id @default(uuid())
  title            String
  content          String   @db.Text
  slug             String   @unique
  media_url        String?
  media_type       String?
  meta_title       String?
  image_alt_text   String?
  meta_description String?  @db.Text
  keywords         String?
  isActive         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  comments ArticleComment[]
  likes    ArticleLike[]
}

model ArticleComment {
  id        String   @id @default(uuid())
  content   String   @db.Text
  status    String   @default("pending")
  createdAt DateTime @default(now())

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  parentId String?
  parent   ArticleComment?  @relation("NestedComments", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ArticleComment[] @relation("NestedComments")
}

model ArticleLike {
  id        String  @id @default(uuid())
  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
}

// ==========================================
// SYSTEM SETTINGS MODELS
// ==========================================

model SiteSettings {
  id          String  @id @default("general_settings")
  siteName    String  @default("Eventomir")
  logoUrl     String?
  logoAltText String?
  faviconUrl  String?
  fontFamily  String  @default("Inter, sans-serif")
  contacts    Json?   @default("{}")
  theme       Json?   @default("{\"backgroundColor\": \"#ffffff\", \"primaryColor\": \"#3b82f6\", \"accentColor\": \"#f59e0b\"}")

  siteCategories  Json @default("[]")
  pageSpecificSEO Json @default("[]")

  updatedAt DateTime @updatedAt
}

model PricingConfig {
  id          String   @id @default("pricing_config")
  config_data Json?
  updated_at  DateTime @updatedAt
}

model Prompt {
  id        String   @id @default(cuid())
  userId    String
  prompt    String   @db.Text
  response  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Float // Negative for payments, positive for top-ups
  type        WalletType // "PAYMENT", "TOPUP", "REFUND", "PAYOUT"
  description String     @db.Text

  createdAt DateTime @default(now())
}

model NotificationLog {
  id           String     @id @default(uuid())
  title        String
  body         String
  targetType   TargetType
  target       String
  status       FCMStatus  @default(SUCCESS)
  messageId    String?
  sentAt       DateTime   @default(now())
  errorDetails String?

  @@index([sentAt])
}

// ==========================================
// PARTNER
// ==========================================

model PartnershipRequest {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  city      String?
  website   String?
  status    Status   @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Partner {
  id                   String  @id @default(uuid())
  referralId           String  @unique // Affiliate link code
  balance              Float   @default(0)
  totalEarned          Float   @default(0)
  totalRegistrations   Int     @default(0)
  totalPaidConversions Int     @default(0)
  clicks               Int     @default(0)
  minPayout            Float   @default(1500)
  paymentDetails       String? @db.Text

  referredUsers User[] @relation("ReferredUsers")

  userId String @unique
  user   User   @relation("PartnerProfile", fields: [userId], references: [id], onDelete: Cascade)

  referralEvents ReferralEvent[]
  payoutRequests PayoutRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReferralEvent {
  id               String  @id @default(cuid())
  partner_id       String
  referred_user_id String?

  commission_amount Float?
  event_type        String
  status            String?  @default("pending")
  created_at        DateTime @default(now())

  partner       Partner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
  referred_user User?   @relation("ReferredUser", fields: [referred_user_id], references: [id], onDelete: Cascade)
}

model PayoutRequest {
  id              String       @id @default(cuid())
  partner_id      String
  amount          Float
  status          PayoutStatus @default(PENDING)
  payment_details String?      @db.Text
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt

  partner Partner @relation(fields: [partner_id], references: [id], onDelete: Cascade)
}

model AudioTrack {
  id           String   @id @default(cuid())
  performer_id String
  title        String
  file_url     String
  created_at   DateTime @default(now())

  performer User @relation(fields: [performer_id], references: [id], onDelete: Cascade)
}

model PromoCode {
  id                 String       @id @default(cuid())
  code               String       @unique
  type               DiscountType
  value              Float
  maxDiscountAmount  Float?
  minOrderAmount     Float?
  isSingleUsePerUser Boolean      @default(false)

  isActive    Boolean   @default(true)
  currentUses Int       @default(0)
  maxUses     Int?
  validUntil  DateTime?

  subscriptions UserSubscription[]
  usedByUsers   User[]             @relation("PromoCodeUsers")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SiteVisit {
  id        String   @id @default(cuid())
  ipAddress String
  userAgent String?
  path      String
  visitedAt DateTime @default(now())

  // To group unique visitors roughly by day
  visitDate DateTime @db.Date

  @@index([visitDate])
  @@index([ipAddress])
}

model SecurityLog {
  id        String   @id @default(cuid())
  ipAddress String
  eventType String // e.g., "RATE_LIMIT_EXCEEDED"
  path      String
  details   String?
  createdAt DateTime @default(now())

  @@index([ipAddress])
  @@index([eventType])
}
